generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------
// 物料与产品基础数据 (Item Master Data)
// ---------------------------------------------------------

enum ItemType {
  PRODUCT   // 成品
  ASSEMBLY  // 半成品/组件
  MATERIAL  // 原材料
}

enum ItemStatus {
  ENABLED
  DISABLED
}

enum ItemSourceType {
  PURCHASED
  MANUFACTURED
  OUTSOURCED
  VIRTUAL
}

model Item {
  id            String         @id @default(uuid())
  itemCode      String         @unique @map("item_code") @db.VarChar(6)
  itemName      String         @map("item_name")
  itemType      ItemType       @map("item_type")
  unit          String
  itemGroup     String?        @map("item_group")
  specification String?        @db.Text
  status        ItemStatus     @default(ENABLED)
  sourceType    ItemSourceType @default(PURCHASED) @map("source_type")
  isPurchasable Boolean        @default(true) @map("is_purchasable")
  requiresFlashing Boolean     @default(false) @map("requires_flashing")
  requiresTraceability Boolean @default(false) @map("requires_traceability")
  requiresDfu Boolean          @default(false) @map("requires_dfu")
  safetyStock   Decimal?       @default(0) @map("safety_stock") @db.Decimal(10, 2)
  imageUrl      String?        @map("image_url") @db.Text
  drawing2dUrl  String?        @map("drawing_2d_url") @db.Text
  drawing3dUrl  String?        @map("drawing_3d_url") @db.Text
  description   String?        @db.Text
  remarks       String?        @db.Text
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  // Relations
  bomsAsParent    BomHeader[] @relation("BomParentItem")
  bomsAsComponent BomLine[]   @relation("BomComponentItem")
  routings        RoutingHeader[]
  inventoryBalances InventoryBalance[]
  inventoryTxns     InventoryTxn[]
  purchaseOrderLines PurchaseOrderLine[]

  @@index([itemType, status])
  @@index([sourceType])
  @@map("items")
}

// ---------------------------------------------------------
// 物料清单 (BOM)
// ---------------------------------------------------------

model BomHeader {
  id             String   @id @default(uuid())
  parentItemCode String   @map("parent_item_code") @db.VarChar(6)
  version        String
  isActive       Boolean  @default(true) @map("is_active")
  effectiveDate  DateTime? @map("effective_date")
  changeNote     String?   @map("change_note") @db.Text
  createdBy      String?   @map("created_by")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relations
  parentItem Item      @relation("BomParentItem", fields: [parentItemCode], references: [itemCode], onDelete: Cascade)
  lines      BomLine[]

  @@unique([parentItemCode, version])
  @@map("bom_headers")
}

model BomLine {
  id                String  @id @default(uuid())
  bomHeaderId       String  @map("bom_header_id")
  componentItemCode String  @map("component_item_code") @db.VarChar(6)
  quantity          Decimal @db.Decimal(10, 4)
  scrapRate         Decimal @default(0) @map("scrap_rate") @db.Decimal(5, 4) // 损耗率，例如0.05表示5%

  // Relations
  bomHeader     BomHeader @relation(fields: [bomHeaderId], references: [id], onDelete: Cascade)
  componentItem Item      @relation("BomComponentItem", fields: [componentItemCode], references: [itemCode], onDelete: Restrict)

  @@unique([bomHeaderId, componentItemCode])
  @@map("bom_lines")
}

// ---------------------------------------------------------
// 工艺路线 (Routing)
// ---------------------------------------------------------

model RoutingHeader {
  id        String   @id @default(uuid())
  itemCode  String   @map("item_code") @db.VarChar(6)
  version   String
  effectiveDate DateTime? @map("effective_date")
  changeNote    String?   @map("change_note") @db.Text
  createdBy     String?   @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  item       Item               @relation(fields: [itemCode], references: [itemCode], onDelete: Cascade)
  operations RoutingOperation[]

  @@unique([itemCode, version])
  @@map("routing_headers")
}

model RoutingOperation {
  id                 String  @id @default(uuid())
  routingHeaderId    String  @map("routing_header_id")
  sequence           Int
  operationName      String  @map("operation_name")
  workstation        String
  standardTimeSec    Int     @map("standard_time_sec") // 标准工时(秒)
  isInspectionPoint  Boolean @default(false) @map("is_inspection_point")
  inspectionStandard String? @map("inspection_standard") @db.Text
  sopUrl             String? @map("sop_url") @db.Text

  // Relations
  routingHeader RoutingHeader @relation(fields: [routingHeaderId], references: [id], onDelete: Cascade)

  @@unique([routingHeaderId, sequence])
  @@map("routing_operations")
}

// ---------------------------------------------------------
// 工作中心 (Work Center)
// ---------------------------------------------------------

enum WorkCenterType {
  FLOW_LINE // 流水线
  STANDALONE // 独立工位
}

model WorkCenter {
  id              String         @id @default(uuid())
  workCenterCode  String         @unique @map("work_center_code") @db.VarChar(16)
  name            String
  type            WorkCenterType
  dailyCapacity   Int?           @map("daily_capacity")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  @@map("work_centers")
}

// ---------------------------------------------------------
// 班组/人员 (Teams & Employees)
// ---------------------------------------------------------

enum SystemRole {
  SUPER_ADMIN
  ENGINEER
  PLANNER
  INVENTORY
  PRODUCTION
  QUALITY
  FINANCE
}

model SystemUser {
  id           String     @id @default(uuid())
  username     String     @unique @db.VarChar(64)
  passwordHash String     @map("password_hash") @db.VarChar(255)
  role         SystemRole @default(PRODUCTION)
  employeeId   String     @unique @map("employee_id")
  isActive     Boolean    @default(true) @map("is_active")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  
  employee     Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("system_users")
}

model Employee {
  id          String      @id @default(uuid())
  employeeNo  String      @unique @map("employee_no") @db.VarChar(32)
  name        String
  team        String
  skills      String[]    @default([])
  skillMatrix String?     @map("skill_matrix") @db.Text
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  
  systemUser  SystemUser?

  @@index([team])
  @@map("employees")
}

// ---------------------------------------------------------
// 组装执行任务 (Assembly Execution)
// ---------------------------------------------------------

enum ExecutionTaskType {
  DFU
  FLASH_REWORK
  BIND_VERIFY
}

enum ExecutionStage {
  PCBA
  ASSEMBLY_EOL
  FINISHED_GOODS
}

enum ExecutionStatus {
  READY
  NEED_DFU
  BLOCKED
  IN_PROGRESS
  DONE
}

model AssemblyExecutionTask {
  id          String            @id @default(uuid())
  skuItemCode String            @map("sku_item_code") @db.VarChar(6)
  batchNo     String            @map("batch_no") @db.VarChar(32)
  serialNo    String            @unique @map("serial_no") @db.VarChar(64)
  bluetoothId String            @unique @map("bluetooth_id") @db.VarChar(64)
  taskType    ExecutionTaskType @map("task_type")
  stage       ExecutionStage
  status      ExecutionStatus   @default(READY)
  failReason  String?           @map("fail_reason") @db.Text
  assignee    String?           @map("assignee") @db.VarChar(64)
  startedAt   DateTime?         @map("started_at")
  finishedAt  DateTime?         @map("finished_at")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  @@index([batchNo, status])
  @@index([skuItemCode, stage])
  @@map("assembly_execution_tasks")
}

model BatchTraceUpload {
  id              String   @id @default(uuid())
  batchNo         String   @map("batch_no") @db.VarChar(32)
  skuItemCode     String   @map("sku_item_code") @db.VarChar(6)
  driveFileUrl    String   @map("drive_file_url") @db.Text
  uploadedBy      String?  @map("uploaded_by") @db.VarChar(64)
  recordCount     Int      @default(0) @map("record_count")
  uploadedAt      DateTime @default(now()) @map("uploaded_at")

  records BatchTraceRecord[]

  @@index([batchNo, uploadedAt])
  @@map("batch_trace_uploads")
}

model BatchTraceRecord {
  id            String   @id @default(uuid())
  uploadId      String   @map("upload_id")
  batchNo       String   @map("batch_no") @db.VarChar(32)
  skuItemCode   String   @map("sku_item_code") @db.VarChar(6)
  serialNo      String   @unique @map("serial_no") @db.VarChar(64)
  bluetoothId   String   @unique @map("bluetooth_id") @db.VarChar(64)
  createdAt     DateTime @default(now()) @map("created_at")

  upload BatchTraceUpload @relation(fields: [uploadId], references: [id], onDelete: Cascade)

  @@index([batchNo])
  @@map("batch_trace_records")
}

enum WorkOrderStatus {
  PLANNED
  RELEASED
  IN_PROGRESS
  DONE
  CANCELLED
}

model WorkOrder {
  id            String          @id @default(uuid())
  workOrderNo   String          @unique @map("work_order_no") @db.VarChar(32)
  salesOrderId  String?         @map("sales_order_id")
  skuItemCode   String          @map("sku_item_code") @db.VarChar(6)
  batchNo       String          @map("batch_no") @db.VarChar(32)
  plannedQty    Int             @map("planned_qty")
  targetVersion String?         @map("target_version") @db.VarChar(32)
  status        WorkOrderStatus @default(PLANNED)
  planStartDate DateTime?       @map("plan_start_date")
  planEndDate   DateTime?       @map("plan_end_date")
  createdBy     String?         @map("created_by") @db.VarChar(64)
  notes         String?         @db.Text
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")
  
  operations    WorkOrderOperation[]
  materialTxns  WorkOrderMaterialTxn[]
  costEntries   CostEntry[]
  issueRecords  IssueRecord[]
  salesOrder    SalesOrder?     @relation(fields: [salesOrderId], references: [id], onDelete: SetNull)

  @@index([skuItemCode, status])
  @@index([batchNo])
  @@map("work_orders")
}

enum WorkOrderOperationStatus {
  PENDING
  STARTED
  PAUSED
  COMPLETED
}

model WorkOrderOperation {
  id                 String  @id @default(uuid())
  workOrderId        String  @map("work_order_id")
  sequence           Int
  operationName      String  @map("operation_name")
  workstation        String
  standardTimeSec    Int     @map("standard_time_sec")
  isInspectionPoint  Boolean @default(false) @map("is_inspection_point")
  inspectionStandard String? @map("inspection_standard") @db.Text
  sopUrl             String? @map("sop_url") @db.Text
  
  status             WorkOrderOperationStatus @default(PENDING)
  completedQty       Int                      @default(0) @map("completed_qty")
  startedAt          DateTime?                @map("started_at")
  completedAt        DateTime?                @map("completed_at")
  
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  workOrder          WorkOrder          @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  productionReports  ProductionReport[]
  issueRecords       IssueRecord[]

  @@unique([workOrderId, sequence])
  @@map("work_order_operations")
}

model ProductionReport {
  id                   String             @id @default(uuid())
  workOrderOperationId String             @map("work_order_operation_id")
  operator             String             @db.VarChar(64)
  goodQty              Int                @map("good_qty")
  scrapQty             Int                @default(0) @map("scrap_qty")
  reworkQty            Int                @default(0) @map("rework_qty")
  timeSpentSec         Int                @default(0) @map("time_spent_sec")
  remarks              String?            @db.Text
  
  createdAt            DateTime           @default(now()) @map("created_at")

  operation            WorkOrderOperation @relation(fields: [workOrderOperationId], references: [id], onDelete: Cascade)

  @@index([workOrderOperationId, createdAt])
  @@map("production_reports")
}

enum QualityInspectionStage {
  IQC
  IPQC
  OQC
}

enum QualityInspectionResult {
  PENDING
  PASS
  FAIL
}

model QualityInspection {
  id           String                  @id @default(uuid())
  inspectionNo String                  @unique @map("inspection_no") @db.VarChar(32)
  stage        QualityInspectionStage
  result       QualityInspectionResult @default(PENDING)
  itemCode     String?                 @map("item_code") @db.VarChar(6)
  batchNo      String?                 @map("batch_no") @db.VarChar(32)
  workOrderNo  String?                 @map("work_order_no") @db.VarChar(32)
  sampleSize   Int                     @default(0) @map("sample_size")
  defectQty    Int                     @default(0) @map("defect_qty")
  issueSummary String?                 @map("issue_summary") @db.Text
  disposition  String?                 @db.Text
  inspectedBy  String?                 @map("inspected_by") @db.VarChar(64)
  inspectedAt  DateTime?               @map("inspected_at")
  createdAt    DateTime                @default(now()) @map("created_at")
  updatedAt    DateTime                @updatedAt @map("updated_at")

  @@index([stage, result, createdAt])
  @@index([itemCode, batchNo])
  @@map("quality_inspections")
}

enum InventoryTxnType {
  IN
  OUT
  TRANSFER
  ADJUST
}

model Warehouse {
  id            String            @id @default(uuid())
  warehouseCode String            @unique @map("warehouse_code") @db.VarChar(16)
  name          String
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")
  locations     StorageLocation[]

  @@map("warehouses")
}

model StorageLocation {
  id           String             @id @default(uuid())
  warehouseId  String             @map("warehouse_id")
  locationCode String             @map("location_code") @db.VarChar(32)
  name         String?
  isActive     Boolean            @default(true) @map("is_active")
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")
  warehouse    Warehouse          @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  balances     InventoryBalance[]
  txnsAsFrom   InventoryTxn[]     @relation("InventoryTxnFromLocation")
  txnsAsTo     InventoryTxn[]     @relation("InventoryTxnToLocation")
  workOrderMaterialTxns WorkOrderMaterialTxn[]
  purchaseReceipts PurchaseReceipt[]

  @@unique([warehouseId, locationCode])
  @@index([isActive])
  @@map("storage_locations")
}

model InventoryBalance {
  id             String          @id @default(uuid())
  itemCode       String          @map("item_code") @db.VarChar(6)
  locationId     String          @map("location_id")
  quantity       Decimal         @default(0) @db.Decimal(14, 3)
  updatedAt      DateTime        @updatedAt @map("updated_at")
  location       StorageLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)
  item           Item            @relation(fields: [itemCode], references: [itemCode], onDelete: Restrict)

  @@unique([itemCode, locationId])
  @@index([locationId])
  @@map("inventory_balances")
}

model InventoryTxn {
  id               String            @id @default(uuid())
  txnType          InventoryTxnType  @map("txn_type")
  itemCode         String            @map("item_code") @db.VarChar(6)
  quantity         Decimal           @db.Decimal(14, 3)
  batchNo          String?           @map("batch_no") @db.VarChar(32)
  fromLocationId   String?           @map("from_location_id")
  toLocationId     String?           @map("to_location_id")
  refType          String?           @map("ref_type") @db.VarChar(32)
  refNo            String?           @map("ref_no") @db.VarChar(64)
  operator         String?           @db.VarChar(64)
  remarks          String?           @db.Text
  createdAt        DateTime          @default(now()) @map("created_at")
  fromLocation     StorageLocation?  @relation("InventoryTxnFromLocation", fields: [fromLocationId], references: [id], onDelete: SetNull)
  toLocation       StorageLocation?  @relation("InventoryTxnToLocation", fields: [toLocationId], references: [id], onDelete: SetNull)
  item             Item              @relation(fields: [itemCode], references: [itemCode], onDelete: Restrict)
  workOrderMaterialTxns WorkOrderMaterialTxn[]
  purchaseReceipts PurchaseReceipt[]

  @@index([itemCode, createdAt])
  @@index([batchNo, createdAt])
  @@index([refType, refNo])
  @@map("inventory_txns")
}

model WorkOrderMaterialTxn {
  id             String    @id @default(uuid())
  workOrderId    String    @map("work_order_id")
  inventoryTxnId String?   @map("inventory_txn_id")
  mode           String    @db.VarChar(16)
  itemCode       String    @map("item_code") @db.VarChar(6)
  locationId     String    @map("location_id")
  quantity       Decimal   @db.Decimal(14, 3)
  batchNo        String?   @map("batch_no") @db.VarChar(32)
  operator       String?   @db.VarChar(64)
  remarks        String?   @db.Text
  createdAt      DateTime  @default(now()) @map("created_at")
  workOrder      WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  location       StorageLocation @relation(fields: [locationId], references: [id], onDelete: Restrict)
  inventoryTxn   InventoryTxn? @relation(fields: [inventoryTxnId], references: [id], onDelete: SetNull)

  @@index([workOrderId, createdAt])
  @@index([itemCode, batchNo])
  @@map("work_order_material_txns")
}

enum CostEntryType {
  MATERIAL
  LABOR
  OVERHEAD
  ADJUSTMENT
}

model CostEntry {
  id          String        @id @default(uuid())
  workOrderId String?       @map("work_order_id")
  entryType   CostEntryType @map("entry_type")
  amount      Decimal       @db.Decimal(14, 2)
  currency    String        @default("CNY") @db.VarChar(8)
  sourceType  String?       @map("source_type") @db.VarChar(32)
  sourceRef   String?       @map("source_ref") @db.VarChar(64)
  notes       String?       @db.Text
  createdBy   String?       @map("created_by") @db.VarChar(64)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  workOrder   WorkOrder?    @relation(fields: [workOrderId], references: [id], onDelete: SetNull)

  @@index([workOrderId, entryType, createdAt])
  @@index([entryType, createdAt])
  @@map("cost_entries")
}

model AuthLoginAudit {
  id         String   @id @default(uuid())
  username   String   @db.VarChar(64)
  ip         String?  @db.VarChar(128)
  userAgent  String?  @map("user_agent") @db.VarChar(255)
  success    Boolean
  reasonCode String?  @map("reason_code") @db.VarChar(64)
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([username, createdAt])
  @@index([success, createdAt])
  @@map("auth_login_audits")
}

enum SalesOrderStatus {
  DRAFT
  CONFIRMED
  PARTIALLY_SHIPPED
  SHIPPED
  CLOSED
  CANCELLED
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PARTIALLY_PAID
  PAID
  VOID
}

model SalesOrder {
  id            String           @id @default(uuid())
  orderNo       String           @unique @map("order_no") @db.VarChar(32)
  customerName  String           @map("customer_name") @db.VarChar(128)
  skuItemCode   String           @map("sku_item_code") @db.VarChar(6)
  batchNo       String?          @map("batch_no") @db.VarChar(32)
  orderedQty    Int              @map("ordered_qty")
  unitPrice     Decimal          @map("unit_price") @db.Decimal(14, 2)
  currency      String           @default("CNY") @db.VarChar(8)
  dueDate       DateTime?        @map("due_date")
  status        SalesOrderStatus @default(DRAFT)
  confirmedAt   DateTime?        @map("confirmed_at")
  confirmedBy   String?          @map("confirmed_by") @db.VarChar(64)
  notes         String?          @db.Text
  createdBy     String?          @map("created_by") @db.VarChar(64)
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")
  shipments     Shipment[]
  invoices      Invoice[]
  workOrders    WorkOrder[]
  mrpRuns       MrpRun[]
  purchaseOrders PurchaseOrder[]

  @@index([customerName, createdAt])
  @@index([skuItemCode, status])
  @@map("sales_orders")
}

model Shipment {
  id            String    @id @default(uuid())
  shipmentNo    String    @unique @map("shipment_no") @db.VarChar(32)
  salesOrderId  String    @map("sales_order_id")
  shippedQty    Int       @map("shipped_qty")
  status        String    @default("POSTED") @db.VarChar(16)
  shippedAt     DateTime  @default(now()) @map("shipped_at")
  postedAt      DateTime? @map("posted_at")
  logisticsNo   String?   @map("logistics_no") @db.VarChar(64)
  warehouseCode String?   @map("warehouse_code") @db.VarChar(16)
  locationId    String?   @map("location_id")
  remarks       String?   @db.Text
  createdBy     String?   @map("created_by") @db.VarChar(64)
  operator      String?   @db.VarChar(64)
  createdAt     DateTime  @default(now()) @map("created_at")
  salesOrder    SalesOrder @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)

  @@index([salesOrderId, shippedAt])
  @@map("shipments")
}

model Invoice {
  id           String        @id @default(uuid())
  salesOrderId String        @map("sales_order_id")
  invoiceNo    String        @unique @map("invoice_no") @db.VarChar(32)
  status       InvoiceStatus @default(DRAFT)
  invoiceType  String        @default("STANDARD") @map("invoice_type") @db.VarChar(32)
  invoiceDate  DateTime?     @map("invoice_date")
  issuedAt     DateTime?     @map("issued_at")
  taxRate      Decimal?      @map("tax_rate") @db.Decimal(6, 4)
  amount       Decimal       @db.Decimal(14, 2)
  paidAmount   Decimal       @default(0) @map("paid_amount") @db.Decimal(14, 2)
  currency     String        @default("CNY") @db.VarChar(8)
  dueDate      DateTime?     @map("due_date")
  notes        String?       @db.Text
  createdBy    String?       @map("created_by") @db.VarChar(64)
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  salesOrder   SalesOrder    @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  payments     Payment[]

  @@index([salesOrderId, status])
  @@index([invoiceDate])
  @@map("invoices")
}

model Payment {
  id          String    @id @default(uuid())
  paymentNo   String    @unique @map("payment_no") @db.VarChar(32)
  invoiceId   String    @map("invoice_id")
  amount      Decimal   @db.Decimal(14, 2)
  paidAt      DateTime  @default(now()) @map("paid_at")
  currency    String    @default("CNY") @db.VarChar(8)
  method      String?   @db.VarChar(32)
  referenceNo String?   @map("reference_no") @db.VarChar(64)
  remarks     String?   @db.Text
  createdBy   String?   @map("created_by") @db.VarChar(64)
  createdAt   DateTime  @default(now()) @map("created_at")
  invoice     Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId, paidAt])
  @@map("payments")
}

enum PurchaseOrderStatus {
  DRAFT
  CONFIRMED
  PARTIALLY_RECEIVED
  RECEIVED
  CLOSED
  CANCELLED
}

model Supplier {
  id           String   @id @default(uuid())
  supplierCode String   @unique @map("supplier_code") @db.VarChar(32)
  name         String   @db.VarChar(128)
  contact      String?  @db.VarChar(64)
  phone        String?  @db.VarChar(32)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  purchaseOrders PurchaseOrder[]

  @@map("suppliers")
}

model PurchaseOrder {
  id              String              @id @default(uuid())
  poNo            String              @unique @map("po_no") @db.VarChar(32)
  salesOrderId    String?             @map("sales_order_id")
  supplierId      String              @map("supplier_id")
  status          PurchaseOrderStatus @default(DRAFT)
  currency        String              @default("CNY") @db.VarChar(8)
  expectedDate    DateTime?           @map("expected_date")
  createdBy       String?             @map("created_by") @db.VarChar(64)
  confirmedAt     DateTime?           @map("confirmed_at")
  confirmedBy     String?             @map("confirmed_by") @db.VarChar(64)
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")
  supplier        Supplier            @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  salesOrder      SalesOrder?         @relation(fields: [salesOrderId], references: [id], onDelete: SetNull)
  lines           PurchaseOrderLine[]
  receipts        PurchaseReceipt[]

  @@index([supplierId, status])
  @@map("purchase_orders")
}

model MrpRun {
  id            String    @id @default(uuid())
  salesOrderId  String    @map("sales_order_id")
  triggeredBy   String?   @map("triggered_by") @db.VarChar(64)
  status        String    @default("DONE") @db.VarChar(16)
  summary       String?   @db.Text
  createdAt     DateTime  @default(now()) @map("created_at")
  salesOrder    SalesOrder @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)

  @@index([salesOrderId, createdAt])
  @@map("mrp_runs")
}

model PurchaseOrderLine {
  id              String        @id @default(uuid())
  purchaseOrderId String        @map("purchase_order_id")
  itemCode        String        @map("item_code") @db.VarChar(6)
  orderedQty      Decimal       @map("ordered_qty") @db.Decimal(14, 3)
  receivedQty     Decimal       @default(0) @map("received_qty") @db.Decimal(14, 3)
  unitPrice       Decimal       @default(0) @map("unit_price") @db.Decimal(14, 2)
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  item            Item          @relation(fields: [itemCode], references: [itemCode], onDelete: Restrict)
  receipts        PurchaseReceipt[]

  @@index([purchaseOrderId])
  @@index([itemCode])
  @@map("purchase_order_lines")
}

model PurchaseReceipt {
  id              String    @id @default(uuid())
  purchaseOrderId String    @map("purchase_order_id")
  lineId          String    @map("line_id")
  inventoryTxnId  String?   @map("inventory_txn_id")
  locationId      String    @map("location_id")
  receivedQty     Decimal   @map("received_qty") @db.Decimal(14, 3)
  batchNo         String?   @map("batch_no") @db.VarChar(32)
  operator        String?   @db.VarChar(64)
  createdAt       DateTime  @default(now()) @map("created_at")
  purchaseOrder   PurchaseOrder     @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  line            PurchaseOrderLine @relation(fields: [lineId], references: [id], onDelete: Cascade)
  inventoryTxn    InventoryTxn?     @relation(fields: [inventoryTxnId], references: [id], onDelete: SetNull)
  location        StorageLocation   @relation(fields: [locationId], references: [id], onDelete: Restrict)

  @@index([purchaseOrderId, createdAt])
  @@map("purchase_receipts")
}

enum IssueType {
  MATERIAL   // 缺料
  QUALITY    // 品质
  EQUIPMENT  // 设备
  PROCESS    // 工艺
  OTHER      // 其他
}

enum IssueStatus {
  OPEN       // 待处理
  IN_PROGRESS // 处理中
  RESOLVED   // 已解决
  CLOSED     // 已关闭
}

model IssueRecord {
  id              String      @id @default(uuid())
  issueType       IssueType   @map("issue_type")
  status          IssueStatus @default(OPEN)
  description     String      @db.Text
  workOrderId     String?     @map("work_order_id")
  operationId     String?     @map("operation_id")
  workCenterCode  String?     @map("work_center_code") @db.VarChar(16)
  reporter        String      @db.VarChar(64)
  responder       String?     @db.VarChar(64)
  reportedAt      DateTime    @default(now()) @map("reported_at")
  respondedAt     DateTime?   @map("responded_at")
  resolvedAt      DateTime?   @map("resolved_at")
  resolution      String?     @db.Text
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  workOrder       WorkOrder?  @relation(fields: [workOrderId], references: [id], onDelete: SetNull)
  operation       WorkOrderOperation? @relation(fields: [operationId], references: [id], onDelete: SetNull)

  @@index([status, issueType])
  @@index([workOrderId])
  @@map("issue_records")
}

model VisitorFeedback {
  id        String   @id @default(uuid())
  content   String   @db.Text
  nickname  String?  @db.VarChar(64)
  contact   String?  @db.VarChar(128)
  ip        String?  @db.VarChar(128)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@map("visitor_feedback")
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String   @db.VarChar(64) // e.g., "REPORT_PRODUCTION", "ADJUST_INVENTORY", "CONFIRM_ORDER"
  entity    String   @db.VarChar(64) // e.g., "WorkOrder", "Inventory", "SalesOrder"
  entityId  String   @map("entity_id") @db.VarChar(64)
  operator  String   @db.VarChar(64)
  details   String?  @db.Text // JSON string of changes
  createdAt DateTime @default(now()) @map("created_at")

  @@index([entity, entityId])
  @@index([operator])
  @@index([createdAt])
  @@map("audit_logs")
}
