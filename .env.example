# PostgreSQL connection string (required on Vercel and for local production-like runs).
# Example: postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require
DATABASE_URL=

# Required: HMAC secret used to sign auth cookies.
# Use a long random value (32+ chars), example generated via openssl rand -base64 48
AUTH_SECRET=

# Required: Super admin credentials as JSON array.
# Example: [{"username":"david","password":"change_me"}]
SUPER_ADMINS_JSON=[]

# Optional safety switch. Keep false in production.
# If true and DATABASE_URL is postgres, build will run prisma db push.
ALLOW_DB_PUSH_ON_BUILD=false

# Required for signing auth session cookies (use a long random value)
AUTH_SECRET=

# JSON array of admin credentials used for login.
# Example: [{"username":"david","password":"replace-me"}]
SUPER_ADMINS_JSON=[]
